# CoreCoder Web Server 配置
# 复制为 .env 并修改

# ── vLLM Qwen3-32B 连接 ──
# vLLM 默认端口 8000，OpenAI 兼容 API 路径 /v1
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=vllm
CORECODER_MODEL=Qwen/Qwen3-32B

# ── vLLM 启动命令（必须带工具调用参数）──
# vllm serve Qwen/Qwen3-32B \
#   --enable-auto-tool-choice \
#   --tool-call-parser hermes \
#   --served-model-name Qwen/Qwen3-32B
# 不带 --enable-auto-tool-choice 和 --tool-call-parser，模型不会发出
# tool_calls，agent 的工具永远不会触发 (10 个问题里的第 10 项)

# ── 可选参数 ──
# CORECODER_MAX_TOKENS=8192
# CORECODER_TEMPERATURE=0.0
# CORECODER_MAX_CONTEXT=128000
