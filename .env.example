# CoreCoder Web Server 配置（部署在 192.168.101.95 服务器上）
# 复制为 .env 并修改

# ── vLLM Qwen3-32B 连接（同一台服务器，用 localhost）──
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=vllm
CORECODER_MODEL=Qwen/Qwen3-32B

# ── 上下文窗口（必须 ≤ vLLM 的 max-model-len=40960）──
# 留余量给模型回复，设 40000
# context.py 会在 50%/70%/90% 三档自动压缩
CORECODER_MAX_CONTEXT=40000
CORECODER_MAX_TOKENS=8192

# ── Word 文档输出目录（默认 ~/.corecoder/docs）──
# CORECODER_OUTPUT_DIR=/opt/corecoder/docs

# ── vLLM 启动命令（必须带工具调用参数）──
# vllm serve Qwen/Qwen3-32B \
#   --enable-auto-tool-choice \
#   --tool-call-parser hermes \
#   --served-model-name Qwen/Qwen3-32B
# 不带以上参数，模型不会发出 tool_calls，agent 的工具永远不会触发
